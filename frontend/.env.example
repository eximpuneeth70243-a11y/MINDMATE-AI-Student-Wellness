# API Configuration
REACT_APP_API_URL=http://localhost:5000
REACT_APP_API_BASE_PATH=/api
REACT_APP_SOCKET_URL=http://localhost:5000
REACT_APP_SOCKET_PATH=/socket.io

# AI & LLM Configuration
REACT_APP_OPENAI_API_KEY=sk-your-openai-key-here
REACT_APP_GEMINI_API_KEY=your-gemini-key-here
REACT_APP_AI_MODEL=gpt-3.5-turbo

# Application Configuration
REACT_APP_APP_NAME=MINDMATE AI
REACT_APP_APP_VERSION=1.0.0
REACT_APP_ENVIRONMENT=development

# Feature Flags
REACT_APP_ENABLE_VOICE_INPUT=true
REACT_APP_ENABLE_DARK_MODE=true
REACT_APP_ENABLE_MEDITATION=true
REACT_APP_ENABLE_EMERGENCY_SUPPORT=true
REACT_APP_ENABLE_JOURNALING=true

# Analytics
REACT_APP_ANALYTICS_ENABLED=true
REACT_APP_ANALYTICS_ID=

# Chat Configuration
REACT_APP_CHAT_MAX_HISTORY=100
REACT_APP_CHAT_AUTO_SCROLL=true
REACT_APP_CHAT_TYPING_INDICATOR=true

# Theme Configuration
REACT_APP_DEFAULT_THEME=light
REACT_APP_PRIMARY_COLOR=#6366f1
REACT_APP_SECONDARY_COLOR=#ec4899

# Wellness Configuration
REACT_APP_MEDITATION_DURATION=300
REACT_APP_BREATHING_DURATION=180
REACT_APP_POMODORO_WORK_DURATION=1500
REACT_APP_POMODORO_BREAK_DURATION=300

# Notifications
REACT_APP_NOTIFICATIONS_ENABLED=true
REACT_APP_NOTIFICATION_TIMEOUT=5000

# Build Configuration
GENERATE_SOURCEMAP=false
CHECK_FOR_UPDATES=true