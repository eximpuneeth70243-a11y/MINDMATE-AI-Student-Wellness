# Server Configuration
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000

# Database Configuration
MONGODB_URI=mongodb://admin:password@localhost:27017/mindmate_db
DB_NAME=mindmate_db
DB_USER=admin
DB_PASSWORD=password

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_REFRESH_EXPIRE=30d

# AI & LLM APIs
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here
AI_MODEL=gpt-3.5-turbo

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@mindmate.ai
SMTP_FROM_NAME=MINDMATE AI

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your_session_secret_key
SESSION_EXPIRY=86400000

# File Upload
MAX_UPLOAD_SIZE=5242880
ALLOWED_FILE_TYPES=.pdf,.jpg,.jpeg,.png,.doc,.docx

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# Admin Configuration
ADMIN_EMAIL=admin@mindmate.ai
ADMIN_PASSWORD=change_this_password

# ML Model Server (Optional)
ML_SERVER_URL=http://localhost:8000
ML_SENTIMENT_MODEL=bert-base-multilingual-uncased-sentiment
ML_INTENT_MODEL=distilbert-base-uncased

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_SAMPLE_RATE=0.1

# Security
BCRYPT_ROUNDS=10
CORF_PROTECTION_ENABLED=true
HELMET_ENABLED=true
SECURE_HEADERS_ENABLED=true